NODE_ENV=development
APP_PORT=3000
APP_NAME=Tingilin API
APP_URL=http://localhost:3000
MONGO_URI=mongodb://localhost:27017/tingilin

# Reverse proxy / load-balancing behavior
TRUST_PROXY=1
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000
HTTP_REQUEST_TIMEOUT_MS=120000
HTTP_JSON_BODY_LIMIT=2mb
HTTP_FORM_BODY_LIMIT=1mb
UPLOADS_CACHE_MAX_AGE=30d
ENABLE_SWAGGER=true

# CORS allow-list (comma separated, no trailing slash)
CORS_ORIGINS=http://localhost:8100,http://localhost:4200,http://localhost:4300

# PM2 scale hint (used by deploy/pm2/ecosystem.config.cjs in production)
PM2_INSTANCES=3

PUBLIC_APP_URL=https://tinguilin.yaba-in.com
PUBLIC_API_URL=https://backend.tinguilin.yaba-in.com

# Default fallback image for any shared page
PUBLIC_SHARE_IMAGE_URL=https://tinguilin.yaba-in.com/assets/img/placeholder.png

# Optional per-context images (used when set)
PUBLIC_SITE_SHARE_IMAGE_URL=https://tinguilin.yaba-in.com/assets/img/Asset_6.png
PUBLIC_REFERRAL_SHARE_IMAGE_URL=https://tinguilin.yaba-in.com/assets/img/referal.jpg
PUBLIC_RAFFLE_SHARE_IMAGE_URL=
PUBLIC_LIVE_SHARE_IMAGE_URL=

# Digikuntz payment provider
DIGIKUNTZ_BASE_URL=
DIGIKUNTZ_USER_ID=
DIGIKUNTZ_SECRET_KEY=
DIGIKUNTZ_WEBHOOK_SECRET=replace-with-a-long-random-secret
DIGIKUNTZ_WEBHOOK_SIGNATURE_MODE=hmac
DIGIKUNTZ_WEBHOOK_TOLERANCE_SECONDS=300
ALLOW_INSECURE_WEBHOOK_SIGNATURE=false
# Mock payments are enabled by default only outside production when this value is empty.
ENABLE_MOCK_PAYMENTS=
# Fallback country used when client does not send userCountry
DIGIKUNTZ_DEFAULT_COUNTRY=CM

# Mail / password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional provider shortcut (example: gmail)
SMTP_SERVICE=
# Set to false only for troubleshooting self-signed TLS certs
SMTP_TLS_REJECT_UNAUTHORIZED=true
# Optional: force TLS SNI/certificate hostname (example: prime.gic.cm)
SMTP_TLS_SERVERNAME=
MAIL_FROM=
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_RESEND_COOLDOWN_SEC=60
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_DEBUG_RESPONSE=false
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
