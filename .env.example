APP_PORT=3000
MONGO_URI=mongodb://localhost:27017/tingilin

APP_NAME=Tingilin
APP_WEB_URL=http://localhost:8100
PUBLIC_APP_URL=http://localhost:8100
PUBLIC_API_URL=http://localhost:3000

JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Required only for admin bootstrap endpoint
SETUP_KEY=CHANGE_ME_SETUP_KEY

# Password reset behavior
PASSWORD_RESET_RESEND_COOLDOWN_SEC=60
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_DEBUG_RESPONSE=false

# SMTP (optional in local)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Tingilin <no-reply@tingilin.local>

# Digikuntz provider (required only if you use DIGIKUNTZ)
DIGIKUNTZ_BASE_URL=
DIGIKUNTZ_USER_ID=
DIGIKUNTZ_SECRET_KEY=

